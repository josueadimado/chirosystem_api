DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars-for-production-to-a-long-random-string-at-least-32-chars
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
POSTGRES_DB=chiroflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
CELERY_BROKER_URL=redis://redis:6379/0

# Do not set DATABASE_URL when using docker-compose.prod.yml — the compose file sets it to
# postgresql://...@db:5432/... so the app reaches Postgres inside Docker. A dev DATABASE_URL
# with "localhost" breaks the API container (migrations fail → unhealthy).

# Django admin bootstrap (optional; run: python manage.py create_admin_from_env)
# DJANGO_ADMIN_USERNAME=admin
# DJANGO_ADMIN_PASSWORD=
# DJANGO_ADMIN_EMAIL=admin@example.com
# DJANGO_ADMIN_FULL_NAME=Site Admin

# Twilio SMS (optional — booking confirmations + day-before reminders)
# https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 from number, e.g. +15551234567
TWILIO_PHONE_NUMBER=

# Twilio Voice (optional — AI phone booking). Public https origin Twilio can reach (no trailing slash).
# Example with ngrok: https://abc123.ngrok-free.app
TWILIO_VOICE_PUBLIC_BASE_URL=
# Dev only (requires DJANGO_DEBUG=1): set to 1 to skip signature validation when testing tunnels.
VOICE_SKIP_TWILIO_SIGNATURE=

# OpenAI (optional — enables speech → booking on voice calls). https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_VOICE_MODEL=gpt-4o-mini

# Used to decide "tomorrow" for reminder texts (IANA tz, e.g. America/Detroit)
CLINIC_TIMEZONE=America/Detroit

# Google Calendar — each doctor connects a personal Gmail / Google account (OAuth)
# Create OAuth "Web client" in Google Cloud Console; add authorized redirect URI exactly:
#   http://localhost:8001/api/v1/doctor/google_calendar/oauth/callback/  (8001 = default Docker dev API host port)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/doctor/google_calendar/oauth/callback/

# Square — https://developer.squareup.com/docs
# Application + token from Developer Dashboard (Sandbox vs Production).
SQUARE_ACCESS_TOKEN=
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
# sandbox | production
SQUARE_ENVIRONMENT=sandbox
# Paired Square Terminal device id (Devices in Dashboard) — required for in-person Terminal checkout from the doctor UI.
SQUARE_DEVICE_ID=
# Webhook: subscribe to payment.updated + terminal.checkout.updated → https://<your-api>/api/v1/square/webhook/
# Signature key from the subscription; NOTIFICATION_URL must match the URL string in the Dashboard exactly.
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=
# Must match the URL you open in the browser (payment link redirect after checkout).
FRONTEND_BASE_URL=http://localhost:3001
# Optional: if Square’s API accepts cancel_url on payment links, set to true (default off).
# SQUARE_CHECKOUT_SEND_CANCEL_URL=true
